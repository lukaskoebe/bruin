{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "generate:api-types": "node ./scripts/generate-api-types.mjs",
    "typecheck": "corepack pnpm run generate:api-types && tsc --noEmit",
    "build": "corepack pnpm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:live": "corepack pnpm build && playwright test --config=playwright.live.config.ts",
    "tutorial:quick-tour": "corepack pnpm build && node ./scripts/tutorials/render-tutorial.mjs ./scripts/tutorials/tutorial-01-quick-tour.json",
    "tutorial:build-pipeline": "corepack pnpm build && node ./scripts/tutorials/render-tutorial.mjs ./scripts/tutorials/tutorial-02-build-a-pipeline.json",
    "audit": "pnpm audit --audit-level=high"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-form": "^1.28.6",
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/react-virtual": "^3.13.23",
    "ansi-to-html": "^0.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "jotai": "^2.19.0",
    "lucide-react": "^0.544.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "reactflow": "^11.11.4",
    "recharts": "2.15.4",
    "shadcn": "^3.8.5",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/router-plugin": "^1.167.8",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "monaco-editor": "0.55.1",
    "rolldown-vite": "^7.3.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
